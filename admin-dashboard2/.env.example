# Copy this file to `.env` (local) or set these in Vercel env vars.
# Never commit real secrets in `.env`/`.env.local`.
#
# Required (local + Vercel)
# - DATABASE_URL (direct) or DATABASE_URL_POOLER (transaction pooler, port 6543)
# - ADMIN_JWT_SECRET
# - Firebase Admin creds for verifying Firebase ID tokens on the API routes
#
# Optional
# - Admin default username/password (local convenience)
# - GROQ/Gemini keys for horoscope generation

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Direct connection (may be blocked/slow on some networks)
DATABASE_URL="postgresql://postgres:PASSWORD@db.<project-ref>.supabase.co:5432/postgres"

# Transaction pooler (recommended esp. on Vercel; port 6543, user postgres.<project-ref>)
DATABASE_URL_POOLER="postgresql://postgres.<project-ref>:PASSWORD@aws-1-<region>.pooler.supabase.com:6543/postgres"

# -----------------------------------------------------------------------------
# Admin dashboard auth
# -----------------------------------------------------------------------------
ADMIN_JWT_SECRET="replace-me-with-a-long-random-string"
ADMIN_DEFAULT_USERNAME=""
ADMIN_DEFAULT_PASSWORD=""

# Allow x-firebase-uid header fallback (local dev only; keep false in production)
ALLOW_HEADER_USER_ID_FALLBACK="false"

# -----------------------------------------------------------------------------
# Firebase Admin (required to verify Authorization: Bearer <Firebase ID token>)
# -----------------------------------------------------------------------------
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
# Paste the private key with literal \n newlines (Vercel style)
FIREBASE_PRIVATE_KEY=""

# -----------------------------------------------------------------------------
# AI horoscope generation (optional)
# -----------------------------------------------------------------------------
GROQ_API_KEY=""
GEMINI_API_KEY=""
