# API: admin-dashboard2. Production: https://astradailyadmin.org/api
# Local: http://localhost:3000/api  |  Device on LAN: http://YOUR_IP:3000/api
EXPO_PUBLIC_API_BASE_URL="https://astradailyadmin.org/api"

# Optional: EAS project UUID for Expo push (same as app.json extra.eas.projectId). Use if expoConfig.extra.eas is missing in dev.
# EXPO_PUBLIC_EAS_PROJECT_ID=""

# Firebase project config
EXPO_PUBLIC_FIREBASE_API_KEY=""
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=""
EXPO_PUBLIC_FIREBASE_PROJECT_ID=""
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=""
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
EXPO_PUBLIC_FIREBASE_APP_ID=""

# Google OAuth — Web client ID is required for expo-auth-session (browser flow + Firebase).
# Add redirect URIs from mobile/GOOGLE-OAUTH-REDIRECTS.md to this Web client in Google Cloud.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=""
# Optional (keep for Firebase / Play Services; not used as OAuth client_id in LoginScreen)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=""
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=""

# Examples (DO NOT COMMIT REAL VALUES):
# EXPO_PUBLIC_API_BASE_URL="http://10.0.2.2:3000/api"         # Android emulator
# EXPO_PUBLIC_API_BASE_URL="http://192.168.1.69:3000/api"     # device on LAN
# EXPO_PUBLIC_EAS_PROJECT_ID="1876d397-8952-4612-b7de-63689f3eaa6e"
# EXPO_PUBLIC_FIREBASE_API_KEY="AIza..."
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID="1234567890-abcdef.apps.googleusercontent.com"
