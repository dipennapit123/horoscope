# ── Connect portfolio to admin (AstraDaily) API ─────────────────────────────
# The horoscope reader calls this app's /api/site-horoscope/[sign], which proxies
# to the admin dashboard. Point at the admin origin + `/api` (not the portfolio site).
#
# Local (admin on port 3001, portfolio on 3000):
#   ASTRADAILY_API_BASE_URL=http://127.0.0.1:3001/api
#
# Production example:
#   ASTRADAILY_API_BASE_URL=https://your-admin-host.com/api

ASTRADAILY_API_BASE_URL=

# ── Portfolio visitor logging (anonymous) ────────────────────────────────────
# Required to write visit events into the same Postgres DB used by the admin.
DATABASE_URL=

# Server-side salt used to hash IP addresses before storing.
# Generate a random string and keep it secret.
VISITOR_IP_SALT=
